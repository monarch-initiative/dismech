            {% for inheritance_item in disorder.inheritance %}
            <div class="item-box inheritance-box">
                <div class="item-name">
                    {{ inheritance_item.name }}
                    {% if inheritance_item.inheritance_term and inheritance_item.inheritance_term.term %}
                    <span class="phenotype-id">
                        <a href="{{ inheritance_item.inheritance_term.term.id | curie_to_url }}" target="_blank">
                            {{ inheritance_item.inheritance_term.term.id }}
                        </a>
                    </span>
                    {% endif %}
                </div>
                {% if inheritance_item.description %}
                <div class="item-desc">{{ inheritance_item.description }}</div>
                {% endif %}
                {{ render_inheritance_meta(inheritance_item) }}
                {{ render_evidence(inheritance_item.evidence) }}
