        .graph-warning li {
            margin: 4px 0;
        }
    </style>
    <script src="https://d3js.org/d3.v7.min.js" integrity="sha384-CjloA8y00+1SDAUkjs099PVfnY2KmDC2BZnws9kh8D/lX1s46w6EPhpXdqMfjK6i" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/dagre@0.8.5/dist/dagre.min.js" integrity="sha384-2IH3T69EIKYC4c+RXZifZRvaH5SRUdacJW7j6HtE5rQbvLhKKdawxq6vpIzJ7j9M" crossorigin="anonymous"></script>
    <script>
    /* Pathograph: interactive D3.js causal mechanism network */
    var NODE_SHAPES = {
        pathophysiology: "roundrect",
        phenotype: "ellipse",
        environmental: "diamond",
        genetic: "hexagon",
        treatment: "rect",
        biochemical: "circle",
        experimental_model: "roundrect",
        computational_model: "roundrect",
        orphan: "roundrect",
        unknown: "roundrect"
    };
    var NODE_TYPE_LABELS = {
        pathophysiology: "Pathophysiology",
        phenotype: "Phenotype",
        environmental: "Environmental",
        genetic: "Genetics / Variants",
        treatment: "Treatments",
        biochemical: "Biochemical",
        experimental_model: "Experimental Models / Non-animal Systems",
        computational_model: "Computational Models",
        orphan: "Uncategorized"
    };
    var NODE_STROKE = {
        pathophysiology: "#93c5fd",
        phenotype: "#fcd34d",
        environmental: "#86efac",
        genetic: "#c4b5fd",
        treatment: "#f9a8d4",
        biochemical: "#a5b4fc",
        experimental_model: "#14b8a6",
        computational_model: "#65a30d",
        orphan: "#dc2626"
    };
    var NODE_TYPE_ICONS = {
        pathophysiology: "⚙",
        phenotype: "◉",
        environmental: "◇",
        genetic: "🧬",
        treatment: "💊",
        biochemical: "⚗",
        experimental_model: "🧫",
        computational_model: "🧮",
        orphan: "?"
    };
    var EXPERIMENTAL_MODEL_TYPE_ICONS = {
        CELL_LINE: "🧫",
        PRIMARY_CELL_CULTURE: "🧫",
        IPSC_DERIVED_MODEL: "🧫",
        ORGANOID: "◍",
        ORGAN_ON_CHIP: "▣",
        CO_CULTURE: "⇄"
    };

    function humanizeEnum(value) {
        return value ? String(value).replace(/_/g, " ") : "";
    }

    function getModelTypeIcon(modelType) {
        return EXPERIMENTAL_MODEL_TYPE_ICONS[modelType] || NODE_TYPE_ICONS.experimental_model;
    }

    function getNodeIcon(nodeData) {
        if (nodeData && nodeData.node_type === "experimental_model") {
            var modelType = nodeData.meta && nodeData.meta.model_type;
            return getModelTypeIcon(modelType);
        }
        if (nodeData && nodeData.node_type === "computational_model") {
            return NODE_TYPE_ICONS.computational_model;
        }
        return NODE_TYPE_ICONS[(nodeData || {}).node_type] || "";
    }

    function isReadoutEdge(edgeData) {
        return edgeData && edgeData.predicate === "readout";
    }

    function edgeStroke(edgeData) {
        if (edgeData.is_orphan) return "#dc2626";
        if (isReadoutEdge(edgeData)) return "#4f46e5";
        return "#9ca3af";
    }

    function edgeDashArray(edgeData) {
        if (edgeData.is_orphan) return "6 4";
        if (isReadoutEdge(edgeData)) return "3 4";
        return "none";
    }

    function edgeMarker(edgeData) {
        if (edgeData.is_orphan) return "url(#pg-arrow-orphan)";
        if (isReadoutEdge(edgeData)) return "url(#pg-arrow-readout)";
        return "url(#pg-arrow)";
    }

    function edgeTitle(edgeData) {
        var parts = [edgeData.source + " -> " + edgeData.target];
        if (edgeData.predicate) parts.push(humanizeEnum(edgeData.predicate));
        if (edgeData.relationship) parts.push(humanizeEnum(edgeData.relationship));
        if (edgeData.direction) parts.push("direction: " + humanizeEnum(edgeData.direction));
        if (edgeData.endpoint_context) parts.push("context: " + humanizeEnum(edgeData.endpoint_context));
        if (edgeData.description) parts.push(edgeData.description);
        return parts.join("\n");
    }

    function renderPathograph(containerId, data) {
        var container = document.getElementById(containerId);
        var svgEl = document.getElementById(containerId + "-svg");
        var tooltipEl = document.getElementById(containerId + "-tooltip");
        var legendEl = document.getElementById(containerId + "-legend");
        if (!data || !data.nodes || !data.nodes.length) return;

        /* -- Dagre layout -- */
        var g = new dagre.graphlib.Graph();
        g.setGraph({ rankdir: "LR", nodesep: 40, ranksep: 80, marginx: 30, marginy: 30 });
        g.setDefaultEdgeLabel(function() { return {}; });

        var nodeMap = {};
        data.nodes.forEach(function(n) {
            nodeMap[n.id] = n;
            var labelLen = n.id.length;
            var w = Math.max(120, Math.min(220, labelLen * 8 + 30));
            var h = 44;
            g.setNode(n.id, { width: w, height: h, label: n.id });
        });
        data.edges.forEach(function(e) {
            g.setEdge(e.source, e.target);
        });
        dagre.layout(g);

        var graphInfo = g.graph();
        var totalW = graphInfo.width + 60;
        var totalH = graphInfo.height + 60;

        /* -- SVG setup with zoom -- */
        var svg = d3.select(svgEl)
            .attr("viewBox", "0 0 " + totalW + " " + totalH)
            .attr("preserveAspectRatio", "xMidYMid meet")
            .style("min-height", Math.min(totalH, 600) + "px");

        var rootG = svg.append("g").attr("class", "pathograph-root");

        var zoom = d3.zoom()
            .scaleExtent([0.3, 3])
            .on("zoom", function(event) {
                rootG.attr("transform", event.transform);
            });
        svg.call(zoom);

        /* -- Arrow marker -- */
        svg.append("defs").append("marker")
            .attr("id", "pg-arrow")
            .attr("viewBox", "0 0 10 6")
            .attr("refX", 10).attr("refY", 3)
            .attr("markerWidth", 8).attr("markerHeight", 6)
            .attr("orient", "auto")
            .append("path")
            .attr("d", "M0,0 L10,3 L0,6 Z")
            .attr("fill", "#9ca3af");

        svg.select("defs").append("marker")
            .attr("id", "pg-arrow-orphan")
            .attr("viewBox", "0 0 10 6")
            .attr("refX", 10).attr("refY", 3)
            .attr("markerWidth", 8).attr("markerHeight", 6)
            .attr("orient", "auto")
            .append("path")
            .attr("d", "M0,0 L10,3 L0,6 Z")
            .attr("fill", "#dc2626");

        svg.select("defs").append("marker")
            .attr("id", "pg-arrow-readout")
            .attr("viewBox", "0 0 10 6")
            .attr("refX", 10).attr("refY", 3)
            .attr("markerWidth", 8).attr("markerHeight", 6)
            .attr("orient", "auto")
            .append("path")
            .attr("d", "M0,0 L10,3 L0,6 Z")
            .attr("fill", "#4f46e5");

        /* -- Draw edges -- */
        var edgesG = rootG.append("g").attr("class", "pg-edges");
        data.edges.forEach(function(e) {
            var dagreEdge = g.edge(e.source, e.target);
            if (!dagreEdge || !dagreEdge.points) return;
            var pts = dagreEdge.points;
            var line = d3.line().x(function(p){return p.x;}).y(function(p){return p.y;}).curve(d3.curveBasis);
            var edgePath = edgesG.append("path")
                .attr("d", line(pts))
                .attr("fill", "none")
                .attr("stroke", edgeStroke(e))
                .attr("stroke-width", 1.8)
                .attr("stroke-dasharray", edgeDashArray(e))
                .attr("marker-end", edgeMarker(e))
                .attr("data-source", e.source)
                .attr("data-target", e.target);
            edgePath.append("title").text(edgeTitle(e));
        });

        /* -- Shape helpers -- */
        function drawNodeShape(sel, nodeData, w, h) {
            var shape = NODE_SHAPES[nodeData.node_type] || "roundrect";
            var stroke = NODE_STROKE[nodeData.node_type] || "#d1d5db";
            var strokeDash = nodeData.is_orphan ? "6 4" : "none";
            if (nodeData.is_orphan) stroke = "#dc2626";

            if (shape === "ellipse") {
                sel.append("ellipse")
                    .attr("rx", w/2).attr("ry", h/2)
                    .attr("fill", nodeData.color).attr("stroke", stroke).attr("stroke-width", 1.5)
                    .attr("stroke-dasharray", strokeDash);
            } else if (shape === "diamond") {
                var dx = w/2, dy = h/2;
                sel.append("polygon")
                    .attr("points", "0,"+(-dy)+" "+(dx)+",0 0,"+(dy)+" "+(-dx)+",0")
                    .attr("fill", nodeData.color).attr("stroke", stroke).attr("stroke-width", 1.5)
                    .attr("stroke-dasharray", strokeDash);
            } else if (shape === "hexagon") {
                var hx = w/2, hy = h/2, inset = w*0.2;
                sel.append("polygon")
                    .attr("points",
                        (-hx+inset)+","+(-hy)+" "+(hx-inset)+","+(-hy)+" "+
                        (hx)+",0 "+(hx-inset)+","+(hy)+" "+
                        (-hx+inset)+","+(hy)+" "+(-hx)+",0")
                    .attr("fill", nodeData.color).attr("stroke", stroke).attr("stroke-width", 1.5)
                    .attr("stroke-dasharray", strokeDash);
            } else if (shape === "circle") {
                var r = Math.min(w, h) / 2;
                sel.append("circle")
                    .attr("r", r)
                    .attr("fill", nodeData.color).attr("stroke", stroke).attr("stroke-width", 1.5)
                    .attr("stroke-dasharray", strokeDash);
            } else if (shape === "rect") {
                sel.append("rect")
                    .attr("x", -w/2).attr("y", -h/2).attr("width", w).attr("height", h)
                    .attr("fill", nodeData.color).attr("stroke", stroke).attr("stroke-width", 1.5)
                    .attr("stroke-dasharray", strokeDash);
            } else {
                /* roundrect (default) */
                sel.append("rect")
                    .attr("x", -w/2).attr("y", -h/2).attr("width", w).attr("height", h)
                    .attr("rx", 8).attr("ry", 8)
                    .attr("fill", nodeData.color).attr("stroke", stroke).attr("stroke-width", 1.5)
                    .attr("stroke-dasharray", strokeDash);
            }
        }

        /* -- Draw nodes -- */
        var nodesG = rootG.append("g").attr("class", "pg-nodes");
        data.nodes.forEach(function(n) {
            var dagreNode = g.node(n.id);
            if (!dagreNode) return;
            var nw = dagreNode.width, nh = dagreNode.height;
            var nodeG = nodesG.append("g")
                .attr("transform", "translate(" + dagreNode.x + "," + dagreNode.y + ")")
                .attr("data-node-type", n.node_type)
                .attr("data-node-id", n.id)
                .style("cursor", "pointer");

            drawNodeShape(nodeG, n, nw, nh);

            /* Node-type icon badge */
            var nodeIcon = getNodeIcon(n);
            if (nodeIcon) {
                var iconStroke = NODE_STROKE[n.node_type] || "#d1d5db";
                var iconBadge = nodeG.append("g")
                    .attr("transform", "translate(" + (-nw/2 + 12) + "," + (-nh/2 + 10) + ")")
                    .style("pointer-events", "none");
                iconBadge.append("circle")
                    .attr("r", 9)
                    .attr("fill", "rgba(255,255,255,0.95)")
                    .attr("stroke", iconStroke)
                    .attr("stroke-width", 1.2);
                iconBadge.append("text")
                    .attr("text-anchor", "middle")
                    .attr("dominant-baseline", "central")
                    .attr("font-size", "10px")
                    .attr("font-family", "\"Apple Color Emoji\", \"Segoe UI Emoji\", \"Noto Color Emoji\", system-ui, sans-serif")
                    .text(nodeIcon);
            }

            /* Label text */
            var label = n.id;
            var maxChars = Math.floor(nw / 7);
            if (label.length > maxChars) label = label.substring(0, maxChars - 1) + "\u2026";
            nodeG.append("text")
                .attr("text-anchor", "middle")
                .attr("dominant-baseline", "central")
                .attr("font-size", "11px")
                .attr("font-family", "system-ui, -apple-system, sans-serif")
                .attr("fill", "#1f2937")
                .text(label);

            /* PDB structure badge */
            var hasPdb = n.meta && n.meta.pdb_structures && n.meta.pdb_structures.length;
            if (hasPdb) {
                var badgeG = nodeG.append("g")
                    .attr("transform", "translate(" + (nw/2 - 10) + "," + (-nh/2 - 6) + ")")
                    .style("cursor", "pointer");
                badgeG.append("circle")
                    .attr("r", 9)
                    .attr("fill", "#1e40af")
                    .attr("stroke", "#fff")
                    .attr("stroke-width", 1.5);
                badgeG.append("text")
                    .attr("text-anchor", "middle")
                    .attr("dominant-baseline", "central")
                    .attr("font-size", "9px")
                    .attr("fill", "#fff")
                    .text("3D");
                badgeG.append("title").text(n.meta.pdb_structures.length + " PDB structure(s)");
                badgeG.on("click", function(event) {
                    event.stopPropagation();
                    var pdbId = n.meta.pdb_structures[0].pdb_id;
                    window.open("https://www.rcsb.org/3d-view/" + pdbId, "_blank");
                });
            }

            /* Interaction: hover */
            nodeG.on("mouseenter", function(event) {
                highlightNode(n.id, true);
                showTooltip(event, n);
            }).on("mouseleave", function() {
                highlightNode(n.id, false);
                hideTooltip();
            }).on("click", function(event) {
                event.stopPropagation();
                highlightNode(n.id, true);
                showTooltip(event, n);
            });
        });

        /* Click on background clears highlight */
        svg.on("click", function() {
            clearHighlight();
            hideTooltip();
        });

        /* -- Highlight helpers -- */
        function highlightNode(nodeId, on) {
            if (!on) { clearHighlight(); return; }
            /* Find connected edges */
            var connectedNodes = new Set([nodeId]);
            data.edges.forEach(function(e) {
                if (e.source === nodeId) connectedNodes.add(e.target);
                if (e.target === nodeId) connectedNodes.add(e.source);
            });
            nodesG.selectAll("g").each(function() {
                var el = d3.select(this);
                var nid = el.attr("data-node-id");
                el.style("opacity", connectedNodes.has(nid) ? 1 : 0.2);
            });
            edgesG.selectAll("path").each(function() {
                var el = d3.select(this);
                var s = el.attr("data-source"), t = el.attr("data-target");
                el.style("opacity", (s === nodeId || t === nodeId) ? 1 : 0.1);
            });
        }

        function clearHighlight() {
            nodesG.selectAll("g").style("opacity", 1);
            edgesG.selectAll("path").style("opacity", 1);
        }

        /* -- Tooltip -- */
        function showTooltip(event, n) {
            function formatHistopathologyTerm(term) {
                var display = term.preferred_term || term.name || term.term_label || term.term_id || "";
                if (term.term_id && term.term_label && term.term_label !== display) {
                    return display + ' -> ' + term.term_id + ' (' + term.term_label + ')';
                }
                if (term.term_id) {
                    return display + ' -> ' + term.term_id;
                }
                return display;
            }

            var html = [];
            var nodeIcon = getNodeIcon(n);
            html.push('<div class="tt-title">' + (nodeIcon ? escapeHtml(nodeIcon) + ' ' : '') + escapeHtml(n.id) + '</div>');
            html.push('<div class="tt-type">' + escapeHtml(NODE_TYPE_LABELS[n.node_type] || n.node_type) + '</div>');
            if (n.description) {
                var desc = n.description;
                if (desc.length > 200) desc = desc.substring(0, 197) + "...";
                html.push('<div class="tt-desc">' + escapeHtml(desc) + '</div>');
            }
            var meta = n.meta || {};
            var metaParts = [];
            if (meta.evidence_count) metaParts.push('<span>Evidence: ' + meta.evidence_count + ' items</span>');
            if (meta.cell_types && meta.cell_types.length) metaParts.push('<span>Cells: ' + escapeHtml(meta.cell_types.join(", ")) + '</span>');
            if (meta.biological_processes && meta.biological_processes.length) metaParts.push('<span>Processes: ' + escapeHtml(meta.biological_processes.join(", ")) + '</span>');
            if (meta.molecular_functions && meta.molecular_functions.length) metaParts.push('<span>Functions: ' + escapeHtml(meta.molecular_functions.join(", ")) + '</span>');
            if (meta.genes && meta.genes.length) metaParts.push('<span>Genes: ' + escapeHtml(meta.genes.join(", ")) + '</span>');
            if (meta.subtypes && meta.subtypes.length) metaParts.push('<span>Subtypes: ' + escapeHtml(meta.subtypes.join(", ")) + '</span>');
            if (meta.locations && meta.locations.length) metaParts.push('<span>Location: ' + escapeHtml(meta.locations.join(", ")) + '</span>');
            if (meta.association) metaParts.push('<span>Association: ' + escapeHtml(meta.association) + '</span>');
            if (meta.presence) metaParts.push('<span>Presence: ' + escapeHtml(meta.presence) + '</span>');
            if (meta.specificity) metaParts.push('<span>Specificity: ' + escapeHtml(meta.specificity) + '</span>');
            if (meta.frequency) metaParts.push('<span>Frequency: ' + escapeHtml(meta.frequency) + '</span>');
            if (meta.severity) metaParts.push('<span>Severity: ' + escapeHtml(meta.severity) + '</span>');
            if (meta.role) metaParts.push('<span>Role: ' + escapeHtml(meta.role) + '</span>');
            if (meta.therapeutic_agents && meta.therapeutic_agents.length) metaParts.push('<span>Agents: ' + escapeHtml(meta.therapeutic_agents.join(", ")) + '</span>');
            if (meta.dietary_modifications && meta.dietary_modifications.length) metaParts.push('<span>Diet: ' + escapeHtml(meta.dietary_modifications.join(", ")) + '</span>');
            if (meta.model_type) metaParts.push('<span>Model type: ' + escapeHtml(((n.node_type === "experimental_model" ? getModelTypeIcon(meta.model_type) + ' ' : '')) + humanizeEnum(meta.model_type)) + '</span>');
            if (meta.model_software) metaParts.push('<span>Software: ' + escapeHtml(meta.model_software) + '</span>');
            if (meta.model_format) metaParts.push('<span>Format: ' + escapeHtml(meta.model_format) + '</span>');
            if (meta.namo_type) metaParts.push('<span>NAMO: ' + escapeHtml(meta.namo_type) + '</span>');
            if (meta.conditions && meta.conditions.length) metaParts.push('<span>Conditions: ' + escapeHtml(meta.conditions.join(", ")) + '</span>');
            if (meta.publication) metaParts.push('<span>Publication: ' + escapeHtml(meta.publication) + '</span>');
            if (meta.variant_count) metaParts.push('<span>Variants: ' + meta.variant_count + '</span>');
            if (meta.variant_type) metaParts.push('<span>Variant type: ' + escapeHtml(meta.variant_type) + '</span>');
            if (meta.clinical_significance) metaParts.push('<span>Clinical significance: ' + escapeHtml(meta.clinical_significance) + '</span>');
            if (meta.regulatory_category) metaParts.push('<span>Regulatory category: ' + escapeHtml(meta.regulatory_category) + '</span>');
            if (meta.term_id) metaParts.push('<span>Term: ' + escapeHtml(meta.term_id) + '</span>');
            if (meta.term_label) metaParts.push('<span>Term label: ' + escapeHtml(meta.term_label) + '</span>');
            if (meta.histopathology_terms && meta.histopathology_terms.length) {
                metaParts.push(
                    '<span>Histopath: ' + escapeHtml(meta.histopathology_terms.map(formatHistopathologyTerm).join("; ")) + '</span>'
                );
            }
            if (metaParts.length) html.push('<div class="tt-meta">' + metaParts.join("") + '</div>');

            /* Linked experimental models */
            if (meta.experimental_models && meta.experimental_models.length) {
                var modelHtml = '<div style="margin-top:8px; padding-top:6px; border-top:1px solid #e5e7eb;">';
                modelHtml += '<div style="font-size:11px; font-weight:600; color:#0f766e; margin-bottom:4px;">Experimental models</div>';
                meta.experimental_models.forEach(function(model) {
                    modelHtml += '<div style="margin:4px 0; font-size:11px;">';
                    modelHtml += '<span style="font-weight:600; color:#0f172a;">' + escapeHtml((getModelTypeIcon(model.model_type) || NODE_TYPE_ICONS.experimental_model) + ' ' + model.name) + '</span>';
                    if (model.model_type) {
                        modelHtml += ' <span style="color:#0f766e; font-size:10px; text-transform:uppercase; letter-spacing:0.03em;">'
                            + escapeHtml(humanizeEnum(model.model_type)) + '</span>';
                    }
                    if (model.description) {
                        modelHtml += '<div style="color:#6b7280; margin-top:2px; line-height:1.4;">'
                            + escapeHtml(model.description) + '</div>';
                    }
                    modelHtml += '</div>';
                });
                modelHtml += '</div>';
                html.push(modelHtml);
            }

            if (meta.computational_models && meta.computational_models.length) {
                var compHtml = '<div style="margin-top:8px; padding-top:6px; border-top:1px solid #e5e7eb;">';
                compHtml += '<div style="font-size:11px; font-weight:600; color:#4d7c0f; margin-bottom:4px;">Computational models</div>';
                meta.computational_models.forEach(function(model) {
                    compHtml += '<div style="margin:4px 0; font-size:11px;">';
                    compHtml += '<span style="font-weight:600; color:#0f172a;">' + escapeHtml((NODE_TYPE_ICONS.computational_model || "") + ' ' + model.name) + '</span>';
                    if (model.model_type) {
                        compHtml += ' <span style="color:#4d7c0f; font-size:10px; text-transform:uppercase; letter-spacing:0.03em;">'
                            + escapeHtml(humanizeEnum(model.model_type)) + '</span>';
                    }
                    if (model.model_software) {
                        compHtml += ' <span style="color:#6b7280;">' + escapeHtml(model.model_software) + '</span>';
                    }
                    if (model.description) {
                        compHtml += '<div style="color:#6b7280; margin-top:2px; line-height:1.4;">'
                            + escapeHtml(model.description) + '</div>';
                    }
                    compHtml += '</div>';
                });
                compHtml += '</div>';
                html.push(compHtml);
            }

            if (meta.readouts && meta.readouts.length) {
                var readoutHtml = '<div style="margin-top:8px; padding-top:6px; border-top:1px solid #e5e7eb;">';
                readoutHtml += '<div style="font-size:11px; font-weight:600; color:#4f46e5; margin-bottom:4px;">Biomarker readouts</div>';
                meta.readouts.forEach(function(readout) {
                    readoutHtml += '<div style="margin:4px 0; font-size:11px;">';
                    readoutHtml += '<span style="font-weight:600; color:#312e81;">' + escapeHtml(readout.target) + '</span>';
                    if (readout.relationship) {
                        readoutHtml += ' <span style="color:#4f46e5; font-size:10px; text-transform:uppercase; letter-spacing:0.03em;">'
                            + escapeHtml(humanizeEnum(readout.relationship)) + '</span>';
                    }
                    if (readout.direction) {
                        readoutHtml += ' <span style="color:#92400e; font-size:10px; text-transform:uppercase; letter-spacing:0.03em;">'
                            + escapeHtml(humanizeEnum(readout.direction)) + '</span>';
                    }
                    if (readout.endpoint_context) {
                        readoutHtml += ' <span style="color:#6b7280;">' + escapeHtml(humanizeEnum(readout.endpoint_context)) + '</span>';
                    }
                    if (readout._regulatory_endpoints && readout._regulatory_endpoints.length) {
                        readoutHtml += '<div style="margin-top:3px; color:#4338ca; line-height:1.35;">';
                        readout._regulatory_endpoints.forEach(function(endpoint) {
                            readoutHtml += '<div>FDA ' + escapeHtml(endpoint.row_id || '');
                            if (endpoint.endpoint_validation_level) {
                                readoutHtml += ' · ' + escapeHtml(humanizeEnum(endpoint.endpoint_validation_level));
                            }
                            if (endpoint.surrogate_endpoint) {
                                readoutHtml += '<div style="color:#6b7280;">' + escapeHtml(endpoint.surrogate_endpoint) + '</div>';
                            }
                            readoutHtml += '</div>';
                        });
                        readoutHtml += '</div>';
                    }
                    if (readout.interpretation || readout.description) {
                        readoutHtml += '<div style="color:#6b7280; margin-top:2px; line-height:1.4;">'
                            + escapeHtml(readout.interpretation || readout.description) + '</div>';
                    }
                    readoutHtml += '</div>';
                });
                readoutHtml += '</div>';
                html.push(readoutHtml);
            }

            /* PDB structures in tooltip */
            if (meta.pdb_structures && meta.pdb_structures.length) {
                var pdbHtml = '<div style="margin-top:8px; padding-top:6px; border-top:1px solid #e5e7eb;">';
                pdbHtml += '<div style="font-size:11px; font-weight:600; color:#1e40af; margin-bottom:4px;">3D Structures</div>';
                meta.pdb_structures.forEach(function(s) {
                    pdbHtml += '<div style="margin:3px 0; font-size:11px;">';
                    pdbHtml += '<a href="https://www.rcsb.org/3d-view/' + escapeHtml(s.pdb_id)
                        + '" target="_blank" style="color:#1e40af; font-weight:600; text-decoration:underline;">'
                        + escapeHtml(s.pdb_id) + '</a>';
                    if (s.ligand) pdbHtml += ' <span style="color:#92400e; background:#fef3c7; padding:1px 4px; border-radius:3px; font-size:10px;">' + escapeHtml(s.ligand) + '</span>';
                    if (s.target_protein) pdbHtml += ' <span style="color:#6b7280;">→ ' + escapeHtml(s.target_protein) + '</span>';
                    if (s.method) pdbHtml += ' <span style="color:#9ca3af; font-size:10px;">(' + escapeHtml(s.method);
                    if (s.resolution_angstrom) pdbHtml += ', ' + s.resolution_angstrom + 'Å';
                    if (s.method) pdbHtml += ')</span>';
                    pdbHtml += '</div>';
                });
                pdbHtml += '</div>';
                html.push(pdbHtml);
            }

            tooltipEl.innerHTML = html.join("");
            tooltipEl.style.opacity = "1";

            /* Position relative to container */
            var rect = container.getBoundingClientRect();
            var x = event.clientX - rect.left + 14;
            var y = event.clientY - rect.top + 14;
            if (x + 330 > rect.width) x = x - 340;
            if (y + 200 > rect.height) y = Math.max(4, y - 200);
            tooltipEl.style.left = x + "px";
            tooltipEl.style.top = y + "px";
        }

        function hideTooltip() {
            tooltipEl.style.opacity = "0";
        }

        function escapeHtml(str) {
            var div = document.createElement("div");
            div.appendChild(document.createTextNode(str));
            return div.innerHTML;
        }

        /* -- Legend -- */
        var typesInGraph = {};
        data.nodes.forEach(function(n) { typesInGraph[n.node_type] = n.color; });
        var activeTypes = new Set(Object.keys(typesInGraph));

        Object.keys(typesInGraph).forEach(function(type) {
            var item = document.createElement("label");
            item.className = "pathograph-legend-item";
            item.setAttribute("data-type", type);
            var checkbox = document.createElement("input");
            checkbox.type = "checkbox";
            checkbox.checked = true;
            checkbox.setAttribute("aria-label", "Toggle " + (NODE_TYPE_LABELS[type] || type));
            item.appendChild(checkbox);
            var swatch = document.createElement("div");
            swatch.className = "pathograph-legend-swatch";
            swatch.style.background = typesInGraph[type];
            swatch.style.borderColor = NODE_STROKE[type] || "#d1d5db";
            item.appendChild(swatch);
            var label = document.createElement("span");
            var icon = NODE_TYPE_ICONS[type] || "";
            label.textContent = (icon ? icon + " " : "") + (NODE_TYPE_LABELS[type] || type);
            item.appendChild(label);
            checkbox.addEventListener("change", function() {
                if (checkbox.checked) {
                    activeTypes.add(type);
                    item.classList.remove("dimmed");
                } else {
                    activeTypes.delete(type);
                    item.classList.add("dimmed");
                }
                filterByType();
            });
            legendEl.appendChild(item);
        });

        function filterByType() {
            nodesG.selectAll("g").each(function() {
                var el = d3.select(this);
                var t = el.attr("data-node-type");
                el.style("display", activeTypes.has(t) ? null : "none");
            });
            edgesG.selectAll("path").each(function() {
                var el = d3.select(this);
                var sNode = nodeMap[el.attr("data-source")];
                var tNode = nodeMap[el.attr("data-target")];
                var sVis = sNode && activeTypes.has(sNode.node_type);
                var tVis = tNode && activeTypes.has(tNode.node_type);
                el.style("display", (sVis && tVis) ? null : "none");
            });
        }
    }
    </script>
</head>
<body>
    <button type="button" class="notice-banner">This resource is in its pre-alpha development stage. Content is actively being curated and may be incomplete or subject to change.</button>
    {# ========== MACROS ========== #}

    {% set modifier_icons = {
        'INCREASED': '↑',
        'DECREASED': '↓',
        'ABNORMAL': '⚠',
        'DYSREGULATED': '↕',
        'ABSENT': '∅'
    } %}

    {# Evidence rendering macro - reusable for any item with evidence #}
    {% macro render_evidence(evidence_list, max_visible=3, accent_color="#64748b") %}
    {% if evidence_list %}
    <details class="evidence-details">
        <summary class="evidence-toggle">
            Show evidence ({{ evidence_list | length }} reference{{ 's' if evidence_list | length != 1 else '' }})
        </summary>
        <div class="evidence-list">
            {% for ev in evidence_list[:max_visible] %}
            <div class="evidence-item">
                <div class="evidence-header">
                    <span class="evidence-ref">
                        <a href="{{ ev.reference | curie_to_url }}" target="_blank">{{ ev.reference }}</a>
                    </span>
                    {% if ev.supports %}
                    <span class="evidence-support support-{{ ev.supports }}">{{ ev.supports }}</span>
                    {% endif %}
                    {% if ev.evidence_source %}
                    <span class="evidence-source source-{{ ev.evidence_source }}">{{ ev.evidence_source | replace('_', ' ') | title }}</span>
                    {% endif %}
                </div>
                {% if ev.snippet %}
                <div class="evidence-snippet">"{{ ev.snippet | truncate(300) }}"</div>
                {% endif %}
                {% if ev.explanation %}
                <div class="evidence-explanation">{{ ev.explanation }}</div>
                {% endif %}
                {% if ev.images %}
                <div class="evidence-images">
                    {% for img_path in ev.images %}
                    {% set img_src = research_root_rel + '/' + img_path %}
                    <figure>
                        <img src="{{ img_src }}" alt="Artifact: {{ img_path | basename }}" loading="lazy">
                        <figcaption>{{ img_path | basename }}</figcaption>
                    </figure>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            {% endfor %}
            {% if evidence_list | length > max_visible %}
            <div class="evidence-more">+ {{ evidence_list | length - max_visible }} more reference{{ 's' if (evidence_list | length - max_visible) != 1 else '' }}</div>
            {% endif %}
        </div>
    </details>
    {% endif %}
    {% endmacro %}

    {# Phenotype contexts rendering macro #}
    {% macro render_phenotype_contexts(contexts) %}
    {% if contexts %}
    <details class="phenotype-contexts">
        <summary class="phenotype-contexts-toggle">
            Context-specific annotations ({{ contexts | length }})
        </summary>
        {% for ctx in contexts %}
        <div class="context-card">
            <div class="context-header">
                {# Genetic context #}
                {% if ctx.genetic_context %}
                <span class="context-label context-label-genetic">Genetic</span>
                {% if ctx.genetic_context.complementation_group %}
                <span class="context-gene-tag">{{ ctx.genetic_context.complementation_group }}</span>
                {% endif %}
                {% if ctx.genetic_context.gene %}
                <span class="context-gene-tag">{{ ctx.genetic_context.gene.preferred_term or ctx.genetic_context.gene.term.label }}</span>
                {% endif %}
                {% if ctx.genetic_context.genes %}
                {% for g in ctx.genetic_context.genes %}
                <span class="context-gene-tag">{{ g.preferred_term or g.term.label }}</span>
                {% endfor %}
                {% endif %}
                {% if ctx.genetic_context.allele_type %}
                <span class="context-gene-tag" style="background: #e9d5ff; color: #6b21a8;">{{ ctx.genetic_context.allele_type }}</span>
                {% endif %}
                {% if ctx.genetic_context.zygosity %}
                <span class="context-gene-tag" style="background: #fce7f3; color: #9d174d;">{{ ctx.genetic_context.zygosity }}</span>
                {% endif %}
                {% endif %}
                {# Sex #}
                {% if ctx.sex %}
                <span class="context-label context-label-sex">{{ ctx.sex }}</span>
                {% endif %}
                {# Population #}
                {% if ctx.population %}
                <span class="context-label context-label-population">{{ ctx.population }}</span>
                {% endif %}
                {# Age range #}
                {% if ctx.age_range %}
                <span class="context-label context-label-age">{{ ctx.age_range }}</span>
                {% endif %}
                {# Subtype #}
                {% if ctx.subtype %}
                <span class="context-label context-label-subtype">{{ ctx.subtype }}</span>
                {% endif %}
                {# Frequency, onset, severity badges #}
                {% if ctx.frequency %}
                <span class="context-freq">{{ ctx.frequency }}</span>
                {% endif %}
                {% if ctx.onset %}
                {% set onset_category = ctx.onset.get('onset_category') %}
                {% set onset_mean = ctx.onset.get('mean_age_years') %}
                {% set onset_min = ctx.onset.get('min_age_years') %}
                {% set onset_max = ctx.onset.get('max_age_years') %}
                {% if onset_category or onset_mean is not none or onset_min is not none or onset_max is not none %}
                <span class="context-onset">Onset:
                  {%- if onset_category %} {{ onset_category }}{% endif -%}
                  {%- if onset_mean is not none and onset_min is not none and onset_max is not none -%}
                    {{ '; ' if onset_category else ' ' }}mean {{ onset_mean }}y (range {{ onset_min }}-{{ onset_max }}y)
                  {%- elif onset_mean is not none -%}
                    {{ '; ' if onset_category else ' ' }}mean {{ onset_mean }}y
                  {%- elif onset_min is not none and onset_max is not none -%}
                    {{ '; ' if onset_category else ' ' }}{{ onset_min }}-{{ onset_max }}y
                  {%- elif onset_min is not none -%}
                    {{ '; ' if onset_category else ' ' }}from {{ onset_min }}y
                  {%- elif onset_max is not none -%}
                    {{ '; ' if onset_category else ' ' }}up to {{ onset_max }}y
                  {%- endif -%}
                </span>
                {% endif %}
                {% endif %}
                {% if ctx.severity %}
                <span class="context-severity">{{ ctx.severity }}</span>
                {% endif %}
            </div>
            {% if ctx.genetic_context and ctx.genetic_context.description %}
            <div class="context-detail">{{ ctx.genetic_context.description }}</div>
            {% endif %}
            {% if ctx.notes %}
            <div class="context-notes">{{ ctx.notes }}</div>
            {% endif %}
            {{ render_evidence(ctx.evidence) }}
        </div>
        {% endfor %}
    </details>
    {% endif %}
    {% endmacro %}

    {% macro render_findings(findings_list) %}
    {% if findings_list %}
    <div class="findings-section">
        <div class="findings-title">Findings</div>
        {% for finding in findings_list %}
        <div class="finding-item">
            {% if finding.statement %}
            <div class="finding-statement">{{ finding.statement }}</div>
            {% endif %}
            {% if finding.supporting_text %}
            <div class="finding-supporting">"{{ finding.supporting_text | truncate(300) }}"</div>
            {% endif %}
            {{ render_evidence(finding.evidence) }}
        </div>
        {% endfor %}
    </div>
    {% endif %}
    {% endmacro %}

    {% macro render_reference_findings(findings_list) %}
    {% if findings_list %}
    <div class="reference-findings">
        {% for finding in findings_list %}
        <div class="reference-finding">
            {% if finding.statement %}
            <div class="reference-finding-statement">{{ finding.statement }}</div>
            {% endif %}
            {% if finding.supporting_text %}
            <div class="reference-finding-supporting">"{{ finding.supporting_text | truncate(300) }}"</div>
            {% endif %}
            {{ render_evidence(finding.evidence, max_visible=1) }}
        </div>
        {% endfor %}
    </div>
    {% endif %}
    {% endmacro %}

    {% macro render_modifier(modifier) %}
    {% if modifier %}
    <span class="tag tag-modifier">
        {{ modifier_icons.get(modifier, '') }} {{ modifier | replace('_', ' ') }}
    </span>
    {% endif %}
    {% endmacro %}

    {% macro render_onset_badge(onset) %}
    {% if onset %}
    {% set onset_category = onset.get('onset_category') %}
    {% set onset_mean = onset.get('mean_age_years') %}
    {% set onset_min = onset.get('min_age_years') %}
    {% set onset_max = onset.get('max_age_years') %}
    {% if onset_category or onset_mean is not none or onset_min is not none or onset_max is not none %}
    <span class="tag tag-classification">
        Onset:
        {%- if onset_category %} {{ onset_category | replace('_', ' ') }}{% endif -%}
        {%- if onset_mean is not none and onset_min is not none and onset_max is not none -%}
          {{ '; ' if onset_category else ' ' }}mean {{ onset_mean }}y (range {{ onset_min }}-{{ onset_max }}y)
        {%- elif onset_mean is not none -%}
          {{ '; ' if onset_category else ' ' }}mean {{ onset_mean }}y
        {%- elif onset_min is not none and onset_max is not none -%}
          {{ '; ' if onset_category else ' ' }}{{ onset_min }}-{{ onset_max }}y
        {%- elif onset_min is not none -%}
          {{ '; ' if onset_category else ' ' }}from {{ onset_min }}y
        {%- elif onset_max is not none -%}
          {{ '; ' if onset_category else ' ' }}up to {{ onset_max }}y
        {%- endif -%}
    </span>
    {% endif %}
    {% endif %}
    {% endmacro %}

    {% macro render_descriptor_qualifiers(descriptor) %}
    {% if descriptor %}
    {{ render_modifier(descriptor.modifier) }}
    {% if descriptor.laterality %}
    <span class="tag tag-classification">Laterality: {{ descriptor.laterality | replace('_', ' ') }}</span>
    {% endif %}
    {% if descriptor.spatial_extent %}
    <span class="tag tag-classification">Extent: {{ descriptor.spatial_extent | replace('_', ' ') }}</span>
    {% endif %}
    {% if descriptor.temporality %}
    <span class="tag tag-classification">Temporal: {{ descriptor.temporality | replace('_', ' ') }}</span>
    {% endif %}
    {% if descriptor.clinical_course %}
    <span class="tag tag-classification">Course: {{ descriptor.clinical_course | replace('_', ' ') }}</span>
    {% endif %}
    {% if descriptor.severity %}
    <span class="tag tag-classification">Severity: {{ descriptor.severity | replace('_', ' ') }}</span>
    {% endif %}
    {% if descriptor.onset %}
    {{ render_onset_badge(descriptor.onset) }}
    {% endif %}
    {% endif %}
    {% endmacro %}

    {% macro render_criteria_list(title, items) %}
    {% if items %}
    <div class="criteria-group">
        <div class="criteria-header">{{ title }}</div>
        <ul class="criteria-list">
            {% for item in items %}
            <li>
                <span class="criteria-term">{{ item.preferred_term }}</span>
                {% if item.description %}
                <span class="criteria-detail">{{ item.description }}</span>
                {% endif %}
            </li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}
    {% endmacro %}

    {% macro render_inheritance_meta(inheritance_item) %}
    {% set has_meta = inheritance_item.inheritance_term or inheritance_item.penetrance or inheritance_item.penetrance_percentage or inheritance_item.expressivity or inheritance_item.de_novo_rate %}
    {% if has_meta %}
    <div class="item-meta">
        {% if inheritance_item.inheritance_term %}
        <span class="tag tag-classification">
            {{ inheritance_item.inheritance_term.preferred_term or (inheritance_item.inheritance_term.term and inheritance_item.inheritance_term.term.label) or 'Inheritance term' }}
        </span>
        {% endif %}
        {% if inheritance_item.penetrance %}
        <span class="tag tag-classification">Penetrance: {{ inheritance_item.penetrance }}</span>
        {% endif %}
        {% if inheritance_item.penetrance_percentage %}
        <span class="tag tag-classification">Penetrance %: {{ inheritance_item.penetrance_percentage }}</span>
        {% endif %}
        {% if inheritance_item.expressivity %}
        <span class="tag tag-classification">Expressivity: {{ inheritance_item.expressivity }}</span>
        {% endif %}
        {% if inheritance_item.de_novo_rate %}
        <span class="tag tag-classification">De novo rate: {{ inheritance_item.de_novo_rate }}</span>
        {% endif %}
    </div>
    {% endif %}
    {% if inheritance_item.parent_of_origin_effect %}
    <div class="item-desc"><strong>Parent-of-origin effect:</strong> {{ inheritance_item.parent_of_origin_effect }}</div>
    {% endif %}
    {% endmacro %}

    {# ========== PAGE CONTENT ========== #}

    <div class="container">
        <nav class="breadcrumb">
            <a href="../../app/index.html">Browse All</a>
            <span> / </span>
            <span>{{ disorder.name }}</span>
        </nav>

        <header class="page-header">
            <h1>{{ disorder.name }}</h1>
            <div class="header-meta">
                {% if disorder.category %}
                <span class="badge badge-category">{{ disorder.category }}</span>
                {% endif %}
                {% if disorder.disease_term and disorder.disease_term.term %}
                <span class="badge badge-mondo">
                    <a href="{{ disorder.disease_term.term.id | curie_to_url }}" target="_blank">
                        {{ disorder.disease_term.term.id }}
                    </a>
                </span>
                {% endif %}
                {% if pathograph_node_count %}
                <a class="badge badge-pathograph" href="#pathograph">Pathograph {{ pathograph_node_count }}</a>
                {% endif %}
                {% for parent in disorder.parents or [] %}
                <span class="badge badge-category" style="background: rgba(255,255,255,0.1);">{{ parent }}</span>
                {% endfor %}
                <button class="badge badge-openscientist" id="os-ask-btn"
                        onclick="toggleOpenScientist()">
                    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="width: 18px; height: 18px; margin-right: 5px; vertical-align: middle;">
                        <path d="M22 18 Q50 18 50 40 Q50 60 78 60 Q78 82 50 82 Q22 82 22 60"
                              fill="none" stroke="white" stroke-width="10" stroke-linecap="round"/>
                        <circle cx="22" cy="18" r="10" fill="rgba(255,255,255,0.9)"/>
                        <circle cx="78" cy="60" r="10" fill="rgba(255,255,255,0.9)"/>
                        <circle cx="22" cy="60" r="10" fill="rgba(255,255,255,0.7)"/>
                    </svg>
                    Ask OpenScientist
                </button>
            </div>
            {% if disorder.description %}
            <p style="margin-top: 16px; font-size: 1rem; line-height: 1.6; opacity: 0.95; position: relative;">
                {{ disorder.description }}
            </p>
            {% endif %}
        </header>

        <!-- OpenScientist panel -->
        <div id="os-panel" class="os-panel">
            <div class="card">
                <div class="card-header">
                    <div class="card-icon" style="background: #ecfdf5; color: #059669;">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="width: 22px; height: 22px;">
                            <path d="M22 18 Q50 18 50 40 Q50 60 78 60 Q78 82 50 82 Q22 82 22 60"
                                  fill="none" stroke="#0891b2" stroke-width="10" stroke-linecap="round"/>
                            <circle cx="22" cy="18" r="10" fill="#06b6d4"/>
                            <circle cx="78" cy="60" r="10" fill="#06b6d4"/>
                            <circle cx="22" cy="60" r="10" fill="#0e7490"/>
                        </svg>
                    </div>
                    <h2 class="card-title">Ask OpenScientist</h2>
                </div>
                <p style="margin: 0 0 12px; font-size: 0.9rem; color: #6b7280;">
                    Ask a research question about {{ disorder.name }}. OpenScientist will conduct
                    autonomous deep research using the Disorder Mechanisms Knowledge Base and PubMed literature (typically 10-30 minutes).
                </p>
                <div class="os-input-row">
                    <input type="text" id="os-question" maxlength="1000"
                           placeholder="What recent evidence supports or challenges these mechanisms?">
                    <button id="os-submit-btn" onclick="osSubmit()">Submit</button>
                </div>
                <div id="os-progress" class="os-progress" aria-live="polite">
                    <span class="os-progress-spinner"></span>
                    <span id="os-progress-text">Submitting...</span>

                    <div class="os-actions">
                        <button onclick="osCancelResearch()">Cancel research</button>
                    </div>
                </div>
                <div id="os-error" class="os-error"></div>
                <p class="os-privacy-note">
                    Do not include personal health information in your question.
                    Questions and results are cached in your browser's local storage.
                </p>
            </div>
        </div>

        <!-- OpenScientist results (populated by JS) -->
        <div id="os-results" style="display: none;">
            <div class="card" id="os-results-card">
                <div class="card-header">
                    <div class="card-icon" style="background: #ecfdf5; color: #059669;">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="width: 22px; height: 22px;">
                            <path d="M22 18 Q50 18 50 40 Q50 60 78 60 Q78 82 50 82 Q22 82 22 60"
                                  fill="none" stroke="#0891b2" stroke-width="10" stroke-linecap="round"/>
                            <circle cx="22" cy="18" r="10" fill="#06b6d4"/>
                            <circle cx="78" cy="60" r="10" fill="#06b6d4"/>
                            <circle cx="22" cy="60" r="10" fill="#0e7490"/>
                        </svg>
                    </div>
                    <h2 class="card-title">OpenScientist Report</h2>
                </div>
                <div id="os-results-meta" style="margin-bottom: 8px; font-size: 0.85rem; color: #6b7280;"></div>
                <div class="report-toggle" onclick="this.nextElementSibling.classList.toggle('show'); this.querySelector('.toggle-indicator').textContent = this.nextElementSibling.classList.contains('show') ? '▾' : '▸'">
                    <span>View full report</span>
                    <span class="toggle-indicator" style="font-size: 0.9rem;">▸</span>
                </div>
                <div class="report-body">
                    <div id="os-report-content" class="report-content"></div>
                </div>
            </div>
        </div>

        <!-- Stats bar -->
        {% set pathophysiology_count = (disorder.pathophysiology or []) | length %}
        {% set histopathology_count = (disorder.histopathology or []) | length %}
        {% set phenotypes_count = (disorder.phenotypes or []) | length %}
        {% set genetic_count = (disorder.genetic or []) | length %}
        {% set treatments_count = (disorder.treatments or []) | length %}
        {% set pathograph_nodes_count = pathograph_node_count or 0 %}
        {% set definitions_count = (disorder.definitions or []) | length %}
        {% set inheritance_count = (disorder.inheritance or []) | length %}
        {% set subtypes_count = (disorder.has_subtypes or []) | length %}
        {% set differentials_count = (disorder.differential_diagnoses or []) | length %}
        {% set datasets_count = (disorder.datasets or []) | length %}
        {% set trials_count = (disorder.clinical_trials or []) | length %}
        {% set experimental_models = disorder.experimental_models or [] %}
        {% set computational_models = disorder.computational_models or [] %}
        {% set experimental_models_count = experimental_models | length %}
        {% set computational_models_count = computational_models | length %}
        {% set models_count = experimental_models_count + computational_models_count %}
        {% set references_count = (disorder.references or []) | length %}
        {% set literature_count = (literature_sections or []) | length %}
        {% set reports_count = (report_sections or []) | length %}
        {% set ns = namespace(mappings_count=0) %}
        {% for mapping_list in (disorder.mappings or {}).values() %}
            {% if mapping_list is sequence and mapping_list is not string %}
