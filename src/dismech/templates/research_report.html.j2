<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ report.disorder_name }} · {{ report.provider_label }} · Deep Research</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin="anonymous">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        {% include '_palette.css.j2' %}

        body {
            font-family: var(--font);
            color: var(--gray-800);
            line-height: 1.7;
            background:
                radial-gradient(circle at top right, rgba(166, 236, 242, 0.42), transparent 24%),
                linear-gradient(180deg, #fff 0%, var(--gray-50) 100%);
        }

        a {
            color: var(--teal);
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        nav {
            position: sticky;
            top: 0;
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--gray-200);
            z-index: 100;
            padding: 0.75rem 1.5rem;
        }

        .nav-inner {
            max-width: var(--max-width);
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .nav-logo {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--teal);
            letter-spacing: -0.02em;
            text-decoration: none;
        }

        .nav-links {
            display: flex;
            gap: 1.2rem;
            align-items: center;
            font-size: 0.875rem;
            flex-wrap: wrap;
        }

        .nav-links a {
            color: var(--gray-600);
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--teal);
            text-decoration: none;
        }

        .gh-icon {
            width: 18px;
            height: 18px;
            vertical-align: middle;
        }

        .layout {
            max-width: var(--max-width);
            margin: 0 auto;
            padding: 1.75rem 1.5rem 4rem;
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(220px, 260px);
            gap: 1.75rem;
            align-items: start;
        }

        .breadcrumb {
            margin-bottom: 1rem;
            font-size: 0.9rem;
            color: var(--gray-600);
        }

        .breadcrumb span {
            color: var(--gray-500);
        }

        .report-header {
            border-bottom: 1px solid var(--gray-200);
            padding-bottom: 1rem;
            margin-bottom: 1.5rem;
        }

        .report-header h1 {
            font-size: 1.9rem;
            font-weight: 700;
            color: var(--teal);
            line-height: 1.15;
            letter-spacing: -0.02em;
            margin-bottom: 0.4rem;
        }

        .report-subtitle {
            font-size: 1.05rem;
            font-style: italic;
            color: var(--gray-700);
            margin-bottom: 0.75rem;
        }

        .report-date {
            font-size: 0.82rem;
            color: var(--gray-500);
            margin-bottom: 0.5rem;
        }

        .report-meta {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            color: var(--gray-600);
        }

        .meta-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.22rem 0.6rem;
            background: #fff;
            border: 1px solid var(--gray-200);
            border-radius: 999px;
            color: var(--gray-700);
        }

        .provider-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            border: 1px solid var(--teal-light);
            background: var(--teal-50);
            border-radius: 999px;
            padding: 3px 10px;
            font-size: 0.82rem;
            color: var(--teal);
            font-weight: 600;
        }

        {% for provider in provider_registry %}
        .provider-pill.provider-{{ provider.key }} {
            border-color: {{ provider.pill.border }};
            background: {{ provider.pill.background }};
            color: {{ provider.pill.color }};
        }
        {% endfor %}

        .report-body {
            background: #fff;
            border: 1px solid var(--gray-200);
            border-radius: 12px;
            box-shadow: 0 6px 30px rgba(17, 24, 39, 0.03);
            padding: 1.6rem 1.8rem;
            overflow-wrap: break-word;
        }

        .report-body h1,
        .report-body h2,
        .report-body h3,
        .report-body h4 {
            color: var(--gray-900);
            line-height: 1.25;
            margin: 1.4rem 0 0.6rem;
        }

        .report-body h1 { font-size: 1.5rem; }
        .report-body h2 { font-size: 1.25rem; }
        .report-body h3 { font-size: 1.08rem; }

        .report-body h1:first-child,
        .report-body h2:first-child,
        .report-body h3:first-child {
            margin-top: 0;
        }

        .report-body p,
        .report-body ul,
        .report-body ol,
        .report-body table,
        .report-body blockquote,
        .report-body pre {
            margin-bottom: 1rem;
        }

        .report-body ul,
        .report-body ol {
            padding-left: 1.4rem;
        }

        .report-body a {
            word-break: break-word;
        }

        .report-body table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }

        .report-body th,
        .report-body td {
            border: 1px solid var(--gray-200);
            padding: 8px 10px;
            text-align: left;
            vertical-align: top;
        }

        .report-body thead {
            background: var(--teal-50);
        }

        .report-body pre {
            background: var(--gray-50);
            border: 1px solid var(--gray-200);
            border-radius: 8px;
            padding: 0.9rem 1rem;
            overflow-x: auto;
            font-size: 0.85rem;
        }

        .report-body code {
            font-size: 0.9em;
        }

        .report-body blockquote {
            border-left: 3px solid var(--teal-light);
            padding-left: 1rem;
            color: var(--gray-600);
        }

        .report-body img {
            max-width: 100%;
            height: auto;
        }

        .sidebar {
            position: sticky;
            top: 5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .side-card {
            background: #fff;
            border: 1px solid var(--gray-200);
            border-radius: 12px;
            box-shadow: 0 6px 30px rgba(17, 24, 39, 0.03);
            padding: 1rem 1.1rem;
        }

        .side-card h2 {
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--teal);
            margin-bottom: 0.7rem;
        }

        .side-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            font-size: 0.9rem;
        }

        .side-links a {
            color: var(--gray-700);
        }

        .side-links a:hover {
            color: var(--teal);
        }

        .side-links .current {
            color: var(--gray-400);
            font-weight: 600;
        }

        .side-links .provider-pill {
            font-size: 0.78rem;
            padding: 2px 8px;
        }

        .report-nav {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            margin-top: 1.5rem;
            font-size: 0.9rem;
        }

        .report-nav a {
            max-width: 45%;
        }

        .report-nav .disabled {
            color: var(--gray-400);
        }

        @media (max-width: 900px) {
            nav {
                padding: 0.7rem 1rem;
            }

            .layout {
                grid-template-columns: 1fr;
                padding: 1.3rem 1rem 2.5rem;
            }

            .sidebar {
                position: static;
            }

            .report-body {
                padding: 1.2rem 1.1rem;
            }
        }
    </style>
</head>
<body>
    <nav>
        <div class="nav-inner">
            <a href="../../" class="nav-logo">dismech</a>
            <div class="nav-links">
                <a href="../../app/index.html">Browse</a>
                <a href="../../app/embeddings/index.html">Embeddings</a>
                <a href="../../details/">Docs</a>
                <a href="../../pages/modules/index.html">Modules</a>
                <a href="../../pages/comorbidities/">Trajectories</a>
                <a href="../../pages/classifications/">Classifications</a>
                <a href="index.html" class="active">Research</a>
                <a href="../../elements/">Schema</a>
                <a href="https://github.com/monarch-initiative/dismech" aria-label="GitHub">
                    <svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                </a>
            </div>
        </div>
    </nav>

    <div class="layout">
        <main>
            <div class="breadcrumb">
                <a href="../../index.html">Home</a>
                <span> / </span>
                <a href="index.html">Deep Research</a>
                <span> / </span>
                <span>{{ report.disorder_name }}</span>
            </div>

            <header class="report-header">
                <h1>{{ report.disorder_name }}</h1>
                {% if report.subtitle %}
                <p class="report-subtitle">{{ report.subtitle }}</p>
                {% endif %}
                {% if report.date %}
                <div class="report-date">{{ report.date }}</div>
                {% endif %}
                <div class="report-meta">
                    <span class="provider-pill provider-{{ report.provider_key }}">{{ report.prefix }}{{ report.provider_label }}</span>
                    {% if report.mondo_id %}
                    <span class="meta-chip">{{ report.mondo_id }}</span>
                    {% endif %}
                    {% if report.model %}
                    <span class="meta-chip">Model: {{ report.model }}</span>
                    {% endif %}
                    {% if report.citation_count %}
                    <span class="meta-chip">{{ report.citation_count }} citations</span>
                    {% endif %}
                </div>
            </header>

            <article class="report-body">
                {{ report.body_html | safe }}
            </article>

            <nav class="report-nav" aria-label="Report navigation">
                {% if prev_report %}
                <a href="{{ prev_report.output_name }}">← {{ prev_report.disorder_name }} ({{ prev_report.provider_label }})</a>
                {% else %}
                <span class="disabled">← Start</span>
                {% endif %}
                {% if next_report %}
                <a href="{{ next_report.output_name }}">{{ next_report.disorder_name }} ({{ next_report.provider_label }}) →</a>
                {% else %}
                <span class="disabled">End →</span>
                {% endif %}
            </nav>
        </main>

        <aside class="sidebar">
            <div class="side-card">
                <h2>This Disorder</h2>
                <ul class="side-links">
                    {% if report.disorder_page_href %}
                    <li><a href="{{ report.disorder_page_href }}">Disorder page ↗</a></li>
                    {% endif %}
                    <li><a href="index.html">All research reports</a></li>
                    {% if report.source_url %}
                    <li><a href="{{ report.source_url }}" target="_blank" rel="noopener noreferrer">View report source ↗</a></li>
                    {% endif %}
                </ul>
            </div>

            {% if siblings %}
            <div class="side-card">
                <h2>Other Reports</h2>
                <ul class="side-links">
                    {% for sibling in siblings %}
                    <li>
                        {% if sibling.output_name == report.output_name %}
                        <span class="provider-pill provider-{{ sibling.provider_key }}">{{ sibling.prefix }}{{ sibling.provider_label }}</span>
                        <span class="current"> (this report)</span>
                        {% else %}
                        <a href="{{ sibling.output_name }}"><span class="provider-pill provider-{{ sibling.provider_key }}">{{ sibling.prefix }}{{ sibling.provider_label }}</span></a>
                        {% endif %}
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
        </aside>
    </div>
</body>
</html>
