        :root {
            /* Canonical dismech editorial palette — single source of truth.
               Included by all page templates via Jinja2 include. */
            --teal: #00838f;
            --teal-mid: #008c99;
            --teal-light: #a6ecf2;
            --teal-50: #e8f6f8;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-300: #d1d5db;
            --gray-500: #6b7280;
            --gray-600: #4b5563;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --gray-900: #111827;
            --font: 'Lora', Georgia, 'Times New Roman', serif;
            --mono: ui-monospace, "SF Mono", "Cascadia Code", monospace;
            --max-width: 960px;
            /* Legacy aliases */
            --primary: var(--teal);
            --primary-light: #0eb5c3;
            --primary-dark: #006e79;
            --secondary: #6366f1;
            --bg: var(--gray-50);
            --card-bg: #ffffff;
            --card: #ffffff;
            --text: var(--gray-800);
            --text-muted: var(--gray-600);
            --border: var(--gray-200);
            --accent: var(--teal);
            --accent-orange: #f59e0b;
            --accent-rose: #f43f5e;
            --accent-violet: #8b5cf6;
            --accent-sky: #0ea5e9;
            --tree-border: var(--teal-light);
            --chip-bg: #e0f2fe;
            --chip-text: #0369a1;
            --banner-bg: #fef3c7;
            --banner-border: #f59e0b;
            --banner-text: #92400e;
        }
