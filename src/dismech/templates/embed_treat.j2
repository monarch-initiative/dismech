{% if t.regimen_term and t.regimen_term.term %}  Regimen: {{ t.regimen_term.preferred_term or t.regimen_term.term.label | default('') }} [{{ t.regimen_term.term.id | default('') }}; canonical label: {{ t.regimen_term.term.label | default('') }}]{% endif %}
