<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>dismech - Deep Research Reports</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin="anonymous">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --teal: #00838f;
            --teal-mid: #008c99;
            --teal-light: #a6ecf2;
            --teal-50: #e8f6f8;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-500: #6b7280;
            --gray-600: #4b5563;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --gray-900: #111827;
            --font: 'Lora', Georgia, 'Times New Roman', serif;
            --max-width: 960px;
        }

        body {
            font-family: var(--font);
            color: var(--gray-800);
            line-height: 1.7;
            background:
                radial-gradient(circle at top right, rgba(166, 236, 242, 0.42), transparent 24%),
                linear-gradient(180deg, #fff 0%, var(--gray-50) 100%);
        }

        a {
            color: var(--teal);
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        nav {
            position: sticky;
            top: 0;
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--gray-200);
            z-index: 100;
            padding: 0.75rem 1.5rem;
        }

        .nav-inner {
            max-width: var(--max-width);
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .nav-logo {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--teal);
            letter-spacing: -0.02em;
        }

        .nav-links {
            display: flex;
            gap: 1.2rem;
            align-items: center;
            font-size: 0.875rem;
            flex-wrap: wrap;
        }

        .nav-links a {
            color: var(--gray-600);
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--teal);
            text-decoration: none;
        }

        .gh-icon {
            width: 18px;
            height: 18px;
            vertical-align: middle;
        }

        .hero-bg {
            background: var(--teal-50);
            border-bottom: 1px solid var(--gray-200);
        }

        .hero {
            max-width: var(--max-width);
            margin: 0 auto;
            padding: 5.25rem 1.5rem 3.25rem;
            display: grid;
            grid-template-columns: minmax(0, 1.35fr) minmax(240px, 0.85fr);
            gap: 1.25rem;
            align-items: end;
        }

        .hero h1 {
            font-size: 2.35rem;
            font-weight: 700;
            color: var(--teal);
            line-height: 1.12;
            margin-bottom: 0.7rem;
            letter-spacing: -0.02em;
        }

        .hero-tagline {
            font-size: 1.15rem;
            font-style: italic;
            color: var(--gray-700);
            margin-bottom: 0.75rem;
        }

        .hero-sub {
            color: var(--gray-600);
            font-size: 1rem;
            max-width: 590px;
            margin-bottom: 1.2rem;
        }

        .stats {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .stat {
            display: inline-flex;
            align-items: center;
            padding: 0.3rem 0.75rem;
            background: #fff;
            border: 1px solid var(--teal-light);
            border-radius: 999px;
            font-size: 0.82rem;
            color: var(--teal);
            font-weight: 600;
        }

        .hero-card {
            background: rgba(255, 255, 255, 0.85);
            border: 1px solid var(--gray-200);
            border-radius: 12px;
            padding: 1.05rem 1.1rem;
        }

        .hero-card h2 {
            font-size: 0.95rem;
            color: var(--gray-900);
            margin-bottom: 0.55rem;
        }

        .hero-card ul {
            padding-left: 1rem;
            color: var(--gray-600);
            font-size: 0.87rem;
        }

        .hero-card li + li {
            margin-top: 0.4rem;
        }

        .main {
            max-width: var(--max-width);
            margin: 0 auto;
            padding: 2rem 1.5rem 4rem;
        }

        .breadcrumb {
            margin-bottom: 1rem;
            font-size: 0.9rem;
            color: var(--gray-600);
        }

        .breadcrumb span {
            color: var(--gray-500);
        }

        .quick-nav {
            display: flex;
            flex-wrap: wrap;
            gap: 0.7rem;
            margin-bottom: 1rem;
        }

        .quick-nav a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.55rem 0.9rem;
            border: 1px solid var(--gray-200);
            border-radius: 8px;
            background: #fff;
            color: var(--gray-700);
            font-size: 0.86rem;
        }

        .quick-nav a:hover {
            border-color: var(--teal-light);
            color: var(--teal);
            text-decoration: none;
        }

        .table-wrap {
            background: #fff;
            border: 1px solid var(--gray-200);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 6px 30px rgba(17, 24, 39, 0.03);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: var(--teal-50);
        }

        th, td {
            padding: 12px 14px;
            text-align: left;
            vertical-align: top;
        }

        th {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--teal);
            border-bottom: 1px solid var(--gray-200);
        }

        tbody tr + tr {
            border-top: 1px solid var(--gray-200);
        }

        tbody tr:hover {
            background: #fcfefe;
        }

        td {
            color: var(--gray-700);
        }

        .providers {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .provider-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            border: 1px solid var(--teal-light);
            background: var(--teal-50);
            border-radius: 999px;
            padding: 3px 9px;
            font-size: 0.8rem;
            color: var(--teal);
            font-weight: 600;
        }

        .provider-count {
            color: var(--gray-600);
            font-weight: 600;
        }

        .empty {
            color: var(--gray-600);
            font-size: 0.95rem;
            padding: 20px;
        }

        @media (max-width: 900px) {
            nav {
                padding: 0.7rem 1rem;
            }

            .hero {
                grid-template-columns: 1fr;
                padding: 4.25rem 1.1rem 2.4rem;
            }

            .hero h1 {
                font-size: 1.6rem;
            }

            .main {
                padding: 1.3rem 1rem 2.5rem;
            }

            .table-wrap {
                overflow-x: auto;
            }

            table {
                min-width: 720px;
            }
        }
    </style>
</head>
<body>
    <nav>
        <div class="nav-inner">
            <span class="nav-logo">dismech</span>
            <div class="nav-links">
                <a href="../../app/index.html">Browse</a>
                <a href="../../app/embeddings/index.html">Embeddings</a>
                <a href="../../details/">Docs</a>
                <a href="../../pages/modules/index.html">Modules</a>
                <a href="../../pages/comorbidities/">Trajectories</a>
                <a href="../../pages/classifications/">Classifications</a>
                <a href="index.html" class="active">Research</a>
                <a href="../../elements/">Schema</a>
                <a href="https://github.com/monarch-initiative/dismech" aria-label="GitHub">
                    <svg class="gh-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                </a>
            </div>
        </div>
    </nav>

    <div class="hero-bg">
        <section class="hero">
            <div>
                <h1>Deep Research Reports</h1>
                <p class="hero-tagline">Integrated literature summaries for every curated disorder</p>
                <p class="hero-sub">
                    Browse deep-research reports by disorder and jump straight into each disorder page's
                    integrated literature summaries section.
                </p>
                <div class="stats">
                    <span class="stat">{{ disorder_count }} disorders</span>
                    <span class="stat">{{ total_reports }} reports</span>
                </div>
            </div>

            <aside class="hero-card">
                <h2>What You Can Do Here</h2>
                <ul>
                    <li>Filter mentally by disorder and provider mix</li>
                    <li>Open directly to each page's literature section</li>
                    <li>Avoid raw report and citation file listings</li>
                </ul>
            </aside>
        </section>
    </div>

    <main class="main">
        <div class="breadcrumb">
            <a href="../../index.html">Home</a>
            <span> / </span>
            <span>Deep Research</span>
        </div>

        <div class="quick-nav">
            <a href="../../app/index.html">Browse Disorders</a>
            <a href="../../pages/modules/index.html">Mechanism Modules</a>
            <a href="../../pages/comorbidities/">Disease Trajectories</a>
            <a href="../../details/">Detailed Docs</a>
        </div>

        <section class="table-wrap">
            {% if disorders %}
            <table>
                <thead>
                    <tr>
                        <th>Disorder</th>
                        <th>Reports</th>
                        <th>Providers</th>
                    </tr>
                </thead>
                <tbody>
                    {% for disorder in disorders %}
                    <tr>
                        <td>
                            {% if disorder.href %}
                            <a href="{{ disorder.href }}">{{ disorder.name }}</a>
                            {% else %}
                            {{ disorder.name }}
                            {% endif %}
                        </td>
                        <td>{{ disorder.report_count }}</td>
                        <td>
                            <div class="providers">
                                {% for provider in disorder.providers %}
                                <span class="provider-pill">
                                    {{ provider.name }}
                                    <span class="provider-count">{{ provider.count }}</span>
                                </span>
                                {% endfor %}
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="empty">No deep-research reports were found in the research directory.</div>
            {% endif %}
        </section>
    </main>
</body>
</html>
