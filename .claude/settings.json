{
  "permissions": {
    "allow": [
      "Bash(just fetch-reference:*)",
      "Bash(just validate:*)",
      "Bash(just validate-terms-file:*)",
      "Bash(just validate-references:*)",
      "Bash(just validate-terms:*)",
      "Bash(just compliance:*)",
      "Bash(just research-disorder:*)",
      "Bash(just list-disorders:*)",
      "Bash(just count-disorders:*)",
      "Bash(just show-field-pattern:*)",
      "Bash(just find-disorder:*)",
      "Bash(just find-cached-refs:*)",
      "Bash(just check-research:*)",
      "Bash(uv run runoak:*)",
      "Bash(uv run linkml-validate:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue view:*)",
      "Bash(wc -l:*)",
      "WebFetch(domain:pmc.ncbi.nlm.nih.gov)",
      "WebSearch(allowed_domains:pubmed.ncbi.nlm.nih.gov)",
      "mcp__ols4__search"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys; print('HOOK RUNNING', file=sys.stderr); sys.exit(0)\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate_disorder_hook.py"
          }
        ]
      }
    ]
  }
}
